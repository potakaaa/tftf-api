{
  "name": "tftf-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "check": "pnpm lint && pnpm typecheck && pnpm --dir apps/web build && pnpm native:build && pnpm test",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "native:build": "pnpm --dir apps/api native:build",
    "format": "turbo format",
    "test": "pnpm --dir apps/api test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "^6"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
